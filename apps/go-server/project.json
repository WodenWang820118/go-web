{
  "name": "go-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/go-server/src",
  "projectType": "application",
  "tags": ["scope:go"],
  "targets": {
    "build": {
      "executor": "@nx/rspack:rspack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "outputPath": "dist/apps/go-server",
        "outputFileName": "main.js",
        "main": "apps/go-server/src/main.ts",
        "tsConfig": "apps/go-server/tsconfig.app.json",
        "assets": ["apps/go-server/src/assets"],
        "generatePackageJson": false,
        "sourceMap": true,
        "optimization": false,
        "outputHashing": "none",
        "typeCheckOptions": {
          "async": false
        },
        "rspackConfig": "apps/go-server/rspack.config.js"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/go-server",
        "command": "vitest run --config vitest.config.mts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/go-server",
        "command": "tsc --noEmit -p tsconfig.app.json"
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/go-server/package.json",
        "{workspaceRoot}/dist/apps/go-server/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/go-server/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "go-server:build:development",
        "runBuildTargetDependencies": true
      },
      "configurations": {
        "production": {
          "buildTarget": "go-server:build:production",
          "watch": false
        }
      }
    },
    "docker:build": {
      "dependsOn": ["build", "prune"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "docker build -f apps/go-server/Dockerfile --tag apps-go-server ."
      }
    },
    "docker:run": {
      "dependsOn": ["docker:build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "docker run {args} apps-go-server"
      }
    }
  }
}
