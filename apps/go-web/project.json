{
  "name": "go-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/go-web/src",
  "tags": ["scope:go"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/go-web",
        "browser": "apps/go-web/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/go-web/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/go-web/public"
          }
        ],
        "styles": ["apps/go-web/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "go-web:build:production"
        },
        "development": {
          "buildTarget": "go-web:build:development"
        }
      },
      "defaultConfiguration": "development",
      "dependsOn": ["go-server:serve"],
      "options": {
        "proxyConfig": "apps/go-web/proxy.conf.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "go-web:build:development",
        "port": 4200,
        "staticFilePath": "dist/apps/go-web/browser",
        "spa": true
      }
    },
    "docker:build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": ".",
        "command": "docker build -f apps/go-web/Dockerfile --tag gx-go-web:latest ."
      }
    }
  }
}
