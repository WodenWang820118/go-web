{
  "name": "go-web-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/go-web-e2e/src",
  "tags": ["scope:go"],
  "implicitDependencies": ["go-web"],
  "// targets": "to see all targets run: nx show project go-web-e2e --web",
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/go-web-e2e",
        "command": "node ../../tools/scripts/e2e/install-playwright-browsers.ts && playwright test"
      },
      "cache": true,
      "inputs": [
        "default",
        "^{projectRoot}/tsconfig*.json",
        "^production",
        { "externalDependencies": ["@playwright/test"] },
        { "env": "PLAYWRIGHT_FULL_BROWSER_MATRIX" },
        { "env": "NX_PLAYWRIGHT_FULL_BROWSER_MATRIX" }
      ],
      "outputs": [
        "{workspaceRoot}/dist/.playwright/apps/go-web-e2e/test-output",
        "{workspaceRoot}/dist/.playwright/apps/go-web-e2e/playwright-report"
      ],
      "parallelism": false
    }
  }
}
